{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "../src/*"],
      "@/assets/*": ["./assets/*"],
      "@core/*": ["../src/*"],
      "dexie": ["./node_modules/dexie"],
      "nanoid": ["./node_modules/nanoid"],
      "fuse.js": ["./node_modules/fuse.js"],
      "chrono-node": ["./node_modules/chrono-node"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "css.d.ts"
  ],
  "exclude": [
    "core/**"
  ]
}
{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*", "../src/*"],
      "@/assets/*": ["./assets/*"],
      "@core/*": ["../src/*"],
      "dexie": ["./node_modules/dexie"],
      "nanoid": ["./node_modules/nanoid"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "css.d.ts"
  ],
  "exclude": [
    "core/**",
    "src/components/**",
    "src/constants/**",
    "src/hooks/**"
  ]
}